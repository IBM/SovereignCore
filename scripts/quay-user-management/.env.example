# Quay Team Setup - Environment Variables
# Copy this file to .env and fill in your values

# Required: Quay registry URL
# Example: https://quay.example.com or https://registry-quay-quay-enterprise.apps.example.com
export QUAY_URL=https://your-quay-registry.example.com

# Required: API Token for Authentication
# Generate this token from Quay UI: Account Settings > Application Tokens > Generate Token
# The token must have superuser privileges (super:user scope) to create users and manage permissions
export QUAY_API_TOKEN=your-superuser-api-token-here

# Required: User to add to teams
# This user will be added to the "sovereign-core-read" team in each organization
# If the user does not exist, it will be created automatically with an auto-generated password
export TEAM_USER_NAME=sovereign-core-read

# Optional: Additional curl options
# Useful for SSL certificate issues, timeouts, or proxy settings
# Examples:
#   - Skip SSL certificate verification (use only in dev/test environments):
#     export CURL_OPTS="--insecure"
#   - Set connection timeout (in seconds):
#     export CURL_OPTS="--connect-timeout 30"
#   - Set maximum time for the entire operation (in seconds):
#     export CURL_OPTS="--max-time 300"
#   - Combine multiple options:
#     export CURL_OPTS="--insecure --connect-timeout 30 --max-time 300"
# export CURL_OPTS=""

# ============================================
# For generate-pull-secret.sh script
# ============================================

# Required for generate-pull-secret.sh: Set one token from Quay UI
# After running create-read-only-account.sh, log in to Quay UI with the credentials
# from the generated auth file, then create either an application token or an OAuth token.
# If both are set, TEAM_USER_OAUTH_TOKEN takes precedence.
# export TEAM_USER_APP_TOKEN=your-application-token-here
# export TEAM_USER_OAUTH_TOKEN=your-oauth-token-here